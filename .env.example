# ════════════════════════════════════════════
# BidVault Environment Settings Template
# Copy this file to .env and replace the values
# ════════════════════════════════════════════

# Server Port
PORT=3000

# MySQL Database Details
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=auction_db
DB_PORT=3306

# Security Keys
JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRES_IN=24h
